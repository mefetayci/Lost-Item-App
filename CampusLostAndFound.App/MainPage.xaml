<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"

xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"

x:Class="CampusLostAndFound.App.MainPage"

Title="Kayıp Eşya Sistemi">

    <Grid>

        <ScrollView>

            <VerticalStackLayout Padding="30,20" Spacing="20">



                <Label x:Name="PageTitleLabel" Text="Kayıp Eşya Platformu" FontSize="26" FontAttributes="Bold" HorizontalOptions="Center" TextColor="White"/>



                <!-- LOKASYON FİLTRESİ -->

                <Picker x:Name="FilterPicker" Title="Lokasyon Seçin..." SelectedIndexChanged="OnFilterChanged" BackgroundColor="#1E1E1E" TextColor="White" HorizontalOptions="Center" WidthRequest="250" Margin="0,0,0,10">

                    <Picker.Items>

                        <x:String>Tüm Lokasyonlar</x:String>

                        <x:String>Maltepe Üniversitesi</x:String>

                        <x:String>City's AVM</x:String>

                        <x:String>Marmaray</x:String>

                    </Picker.Items>

                </Picker>



                <SearchBar x:Name="ItemSearchBar" Placeholder="Eşya Ara (Örn: Anahtar...)" TextChanged="OnSearchBarTextChanged" Margin="0,0,0,10"/>



                <Button x:Name="AdminAddButton" Text="+ Yeni Eşya Ekle" IsVisible="False" Clicked="OnAddButtonClicked" BackgroundColor="#512BD4" TextColor="White" CornerRadius="20" HorizontalOptions="Center" Margin="0,0,0,10"/>



                <Border StrokeShape="RoundRectangle 10" Padding="15" Stroke="#333333" StrokeThickness="1">

                    <CollectionView x:Name="ItemsCollectionView">

                        <CollectionView.ItemTemplate>

                            <DataTemplate>

                                <Border StrokeShape="RoundRectangle 10" Padding="15" Stroke="#333333" StrokeThickness="1" Margin="0,0,0,10">

                                    <Border.GestureRecognizers>

                                        <TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="{Binding .}"/>

                                    </Border.GestureRecognizers>



                                    <Grid ColumnDefinitions="100, *">

                                        <Image Grid.Column="0" Source="{Binding FullImageUrl}" HeightRequest="90" WidthRequest="90" Aspect="AspectFill" Margin="0,0,15,0" />

                                        <VerticalStackLayout Grid.Column="1" Spacing="5">



                                            <!-- Eşyanın Hangi Kuruma Ait Olduğunu Gösteren Mor Etiket -->

                                            <Label Text="{Binding category, StringFormat='📍 {0}'}" FontSize="12" TextColor="#512BD4" FontAttributes="Bold" />



                                            <Label Text="{Binding title}" FontSize="18" FontAttributes="Bold" />

                                            <Label Text="{Binding location, StringFormat='Bulunan Yer: {0}'}" FontSize="14" TextColor="Gray" />

                                            <Label Text="{Binding finderName, StringFormat='Bulan: {0}'}" FontSize="12" TextColor="Gray" />



                                            <Button x:Name="AdminDeliverButton" Text="Sahibine Teslim Et" BackgroundColor="#28a745" TextColor="White" CornerRadius="5" HeightRequest="35" Margin="0,10,0,0"

CommandParameter="{Binding id}" Clicked="OnHandOverButtonClicked" IsVisible="{Binding IsAdminMode}"/>

                                        </VerticalStackLayout>

                                    </Grid>

                                </Border>

                            </DataTemplate>

                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </Border>

            </VerticalStackLayout>

        </ScrollView>




        <Grid x:Name="LoginOverlay" BackgroundColor="#121212" IsVisible="False">

            <Border StrokeShape="RoundRectangle 20" Stroke="#512BD4" StrokeThickness="2" BackgroundColor="#1E1E1E" WidthRequest="320" HeightRequest="280" HorizontalOptions="Center" VerticalOptions="Center">

                <VerticalStackLayout Padding="20" Spacing="15" VerticalOptions="Center">

                    <Label Text="Görevli Girişi" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />

                    <Label Text="Kurum şifrenizi girin (maltepe, citys, marmaray)" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />

                    <Entry x:Name="PasswordEntry" Placeholder="Şifre" IsPassword="True" HorizontalTextAlignment="Center" />

                    <Button Text="Giriş Yap" BackgroundColor="#512BD4" TextColor="White" CornerRadius="10" Clicked="OnLoginConfirmClicked" />

                    <Button Text="Vazgeç (Öğrenci Girişi)" BackgroundColor="Transparent" TextColor="LightGray" Clicked="OnLoginCancelClicked" />

                </VerticalStackLayout>

            </Border>

        </Grid>



        <!-- Teslimat Onay Ekranı -->

        <Grid x:Name="HandoverOverlay" BackgroundColor="#CC000000" IsVisible="False">

            <Border StrokeShape="RoundRectangle 20" Stroke="#28a745" StrokeThickness="2" BackgroundColor="#1E1E1E" WidthRequest="360" HeightRequest="450" HorizontalOptions="Center" VerticalOptions="Center">

                <VerticalStackLayout Padding="20" Spacing="15" VerticalOptions="Center">

                    <Label Text="Teslimat Onayı ve Hukuki Beyan" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" TextColor="White" />

                    <Border BackgroundColor="#2D2D2D" StrokeShape="RoundRectangle 10" Padding="15" HeightRequest="180">

                        <ScrollView>

                            <Label Text="6698 sayılı Kişisel Verilerin Korunması Kanunu (KVKK) kapsamında, kimlik ve iletişim bilgilerimin yalnızca kayıp eşya teslim süreçlerinin yürütülmesi ve güvenliğinin sağlanması amacıyla işlenmesine, kaydedilmesine ve mevzuatın gerektirdiği süre boyunca muhafaza edilmesine açık rızamla onay veriyorum.&#x0a;&#x0a;Ayrıca, teslim almak üzere olduğum bu eşyanın yasal ve gerçek sahibi olduğumu beyan ederim. Yalan, eksik veya yanıltıcı beyanda bulunarak başkasına ait bir eşyayı teslim almam halinde, Türk Ceza Kanunu'nun (TCK) ilgili maddeleri (Dolandırıcılık ve Hırsızlık) uyarınca doğacak tüm idari, cezai ve hukuki sorumlulukları gayrikabili rücu kabul ve taahhüt ederim." FontSize="13" TextColor="LightGray" LineBreakMode="WordWrap" />

                        </ScrollView>

                    </Border>

                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">

                        <CheckBox x:Name="ConsentCheckBox" Color="#28a745" />

                        <Label Text="Okudum, anladım ve tüm hukuki sorumluluğu kabul ediyorum." FontSize="12" VerticalOptions="Center" TextColor="White" WidthRequest="260" LineBreakMode="WordWrap" />

                    </HorizontalStackLayout>

                    <Button Text="İmzala ve Teslim Al" BackgroundColor="#28a745" TextColor="White" CornerRadius="10" Clicked="OnConfirmHandoverAction" Margin="0,10,0,0"/>

                    <Button Text="Vazgeç" BackgroundColor="Transparent" TextColor="LightGray" Clicked="OnCancelHandoverAction" />

                </VerticalStackLayout>

            </Border>

        </Grid>

    </Grid>
</ContentPage>