<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CampusLostAndFound.App.LoginPage"
             Title="Kurumsal Giriş"
             BackgroundColor="#121212">

    <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">
        <Label Text="🏢" FontSize="60" HorizontalOptions="Center" />
        <Label Text="Görevli Girişi" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" TextColor="White" />
        <Label Text="Lütfen kurum şifrenizi giriniz." FontSize="14" TextColor="Gray" HorizontalOptions="Center" />

        <Entry x:Name="PasswordEntry" Placeholder="Şifre (maltepe, citys, marmaray)" IsPassword="True" BackgroundColor="#1E1E1E" TextColor="White" HorizontalTextAlignment="Center" Margin="0,10,0,0"/>

        <Button Text="Giriş Yap" Clicked="OnLoginClicked" BackgroundColor="#512BD4" TextColor="White" CornerRadius="10" HeightRequest="50" FontAttributes="Bold" FontSize="16" Margin="0,10,0,0" />
    </VerticalStackLayout>
</ContentPage>